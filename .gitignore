# Ignore datasets and massive media
data/
*.mp4
*.MOV
*.jpg
# Ignore the data, but keep the code
src/data/*.zip
src/data/*.csv
src/data/*.jpg
src/data/*.png
# But DON'T ignore __init__.py
!src/data/__init__.py

# Ignore ML model weights (unless they are very small Nano models)
runs/
*.pt
*.onnx

# Ignore Python cache and environments
__pycache__/
.venv/
.env

# Ignore MLflow tracking data
mlruns/
mlartifacts/
.trash/